import { useEffect, useMemo, useRef, useState } from 'react';
import {
  clearPlayerPhotoCache,
  getPlayerPhotoByName,
  playerPhotoUrl,
} from '../services/apiFootball.js';

/**
 * ApiPlayerImage
 * --------------
 * Resolution priority (high → low confidence):
 *   1. preferredSrc            (caller's best-known URL, e.g. portraitFor())
 *   2. direct API-Football URL (built ONLY from a valid API player id)
 *   3. fallbackSrc             (caller's static/curated fallback)
 *   4. getPlayerPhotoByName()  (fuzzy name search — FINAL fallback only)
 *   5. neutral placeholder
 *
 * The old pipeline led with fuzzy name matching and cached the guess for seven
 * days, which is what attached wrong faces and made them survive refreshes.
 * Fuzzy is now quarantined to the very last step and only runs once every
 * higher-confidence source has actually failed to load.
 *
 * IMPORTANT (requirement #2): this component treats `apiPlayerId` / `apiId` /
 * `playerId` as a *trusted* API-Football id. It can validate the shape (must be
 * a positive integer) but it CANNOT distinguish a Supabase row id from a real
 * API id — both are integers, and a coincidental match loads a valid wrong
 * photo without firing onError. That distinction must be enforced upstream in
 * Players.jsx `apiIdFor()` (see the note in the chat reply).
 */

// Bump this string whenever the resolution logic changes. On the next load,
// any browser still on an older version evicts its (possibly wrong) cached
// portraits exactly once, then records the new version.
const PORTRAIT_CACHE_VERSION = 'v3-id-first';
const PORTRAIT_CACHE_VERSION_KEY = 'calibre:portraitCacheVersion';

// Run-once, version-gated migration. Uses the app's own cache clearer so it
// always targets the correct keys.
(function migratePortraitCache() {
  if (typeof window === 'undefined') return;
  try {
    const current = window.localStorage.getItem(PORTRAIT_CACHE_VERSION_KEY);
    if (current !== PORTRAIT_CACHE_VERSION) {
      clearPlayerPhotoCache();
      window.localStorage.setItem(PORTRAIT_CACHE_VERSION_KEY, PORTRAIT_CACHE_VERSION);
    }
  } catch {
    /* localStorage unavailable — nothing to migrate */
  }
})();

// Self-contained neutral avatar so the final fallback never 404s.
const PLACEHOLDER_SRC =
  "data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'%3E" +
  "%3Crect width='64' height='64' fill='%231a1c1f'/%3E" +
  "%3Ccircle cx='32' cy='25' r='12' fill='%2331363b'/%3E" +
  "%3Cpath d='M12 60c0-11 9-19 20-19s20 8 20 19' fill='%2331363b'/%3E%3C/svg%3E";

// API-Football player ids are positive integers. Reject strings, 0, negatives,
// NaN, etc. (This is a shape guard, NOT a row-id/api-id discriminator.)
function toApiPlayerId(value) {
  if (value === null || value === undefined || value === '') return null;
  const n = Number(value);
  return Number.isInteger(n) && n > 0 ? n : null;
}

function isUsableSrc(src) {
  return typeof src === 'string' && /^https?:\/\//i.test(src.trim());
}

function directPortraitUrl(apiId) {
  // Prefer the codebase's canonical builder; fall back to the known pattern.
  const built = typeof playerPhotoUrl === 'function' ? playerPhotoUrl(apiId) : null;
  if (isUsableSrc(built)) return built;
  return `https://media.api-sports.io/football/players/${apiId}.png`;
}

export default function ApiPlayerImage({
  // Identity — explicit api-id-named props are preferred. `playerId` is kept
  // for backward compatibility with existing call sites.
  apiPlayerId,
  apiId,
  playerId,
  name,
  preferredSrc,
  fallbackSrc,
  className,
  alt,
  loading = 'lazy',
  ...rest
}) {
  const resolvedApiId = useMemo(
    () => toApiPlayerId(apiPlayerId ?? apiId ?? playerId),
    [apiPlayerId, apiId, playerId]
  );

  // Synchronous, ordered, de-duplicated candidate URLs. Fuzzy is intentionally
  // NOT here — it is fetched lazily only after these all fail.
  const baseCandidates = useMemo(() => {
    const list = [];
    if (isUsableSrc(preferredSrc)) list.push(preferredSrc.trim());
    if (resolvedApiId) list.push(directPortraitUrl(resolvedApiId));
    if (isUsableSrc(fallbackSrc)) list.push(fallbackSrc.trim());
    return [...new Set(list)];
  }, [preferredSrc, resolvedApiId, fallbackSrc]);

  const [srcIndex, setSrcIndex] = useState(0);
  const [fuzzySrc, setFuzzySrc] = useState(null);
  const [fuzzyTried, setFuzzyTried] = useState(false);

  // Reset the state machine whenever the identity inputs change.
  useEffect(() => {
    setSrcIndex(0);
    setFuzzySrc(null);
    setFuzzyTried(false);
  }, [baseCandidates, name]);

  const exhaustedBase = srcIndex >= baseCandidates.length;

  // Final fallback: fuzzy name search, fired once, only after every
  // higher-confidence source has failed (or none existed).
  useEffect(() => {
    if (!exhaustedBase || fuzzyTried || !name) return;
    let active = true;
    setFuzzyTried(true);
    Promise.resolve(getPlayerPhotoByName(name))
      .then((url) => {
        if (active && isUsableSrc(url)) setFuzzySrc(url);
      })
      .catch(() => {
        /* swallow — placeholder will be shown */
      });
    return () => {
      active = false;
    };
  }, [exhaustedBase, fuzzyTried, name]);

  const currentSrc = !exhaustedBase
    ? baseCandidates[srcIndex]
    : fuzzySrc || PLACEHOLDER_SRC;

  const handleError = () => {
    if (!exhaustedBase) {
      setSrcIndex((i) => i + 1); // advance through base candidates
    } else if (fuzzySrc) {
      setFuzzySrc(null); // fuzzy result also broke → drop to placeholder
    }
  };

  return (
    <img
      {...rest}
      className={className}
      src={currentSrc}
      alt={alt ?? name ?? 'Player'}
      loading={loading}
      onError={handleError}
    />
  );
}
